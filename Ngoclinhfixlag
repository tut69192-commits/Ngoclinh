local RunService = game:GetService("RunService")
local StatsService = game:GetService("Stats")
local Players = game:GetService("Players")
local frameCount = 0
local acc = 0
local updateInterval = 0.5

RunService.Heartbeat:Connect(function(dt)
    frameCount = frameCount + 1
    acc = acc + dt
    if acc >= updateInterval then
        local fps = math.floor(frameCount / acc + 0.5)
        frameCount = 0
        acc = 0

        -- Try getting ping from Stats service; fallback to N/A
        local pingText = "N/A"
        pcall(function()
            -- Common path in some clients: Stats.Network.ServerStatsItem["Data Ping"]
            if StatsService and StatsService.Network and StatsService.Network.ServerStatsItem then
                local item = StatsService.Network.ServerStatsItem["Data Ping"]
                if item and item.Value then
                    pingText = tostring(math.floor(item.Value))
                end
            elseif StatsService and StatsService.Network and StatsService.Network.ClientPing then
                pingText = tostring(math.floor(StatsService.Network.ClientPing))
            end
        end)

        -- Get players count and names (limit to first 10 names for display)
        local playerList = Players:GetPlayers()
        local playerCount = #playerList
        local names = {}
        for i, pl in ipairs(playerList) do
            table.insert(names, pl.Name)
            if i >= 10 then break end
        end
        local namesText = ""
        if #names > 0 then
            namesText = table.concat(names, ", ")
            if playerCount > 10 then
                namesText = namesText .. ", ..."
            end
        else
            namesText = "(no players)"
        end

        StatsLabel.Text = string.format("FPS: %d\nPing: %s ms\nPlayers: %d\n%s", fps, pingText, playerCount, namesText)
    end
end)


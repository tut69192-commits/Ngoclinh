ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0,250,0,120)
Main.Position = UDim2.new(0.5,-125,0.5,-60)
Main.BackgroundColor3 = Color3.fromRGB(30,30,30)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true
Main.Name = "MainMenu"

Instance.new("UICorner", Main).CornerRadius = UDim.new(0,15)

local Dark = Instance.new("Frame", Main)
Dark.Size = UDim2.new(1,0,1,0)
Dark.BackgroundColor3 = Color3.new(0,0,0)
Dark.BackgroundTransparency = 0.45
Instance.new("UICorner", Dark).CornerRadius = UDim.new(0,15)

local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1,0,0,35)
Title.BackgroundTransparency = 1
Title.Text = "Fix Lag"
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.TextColor3 = Color3.fromRGB(255,255,255)

local Fix = Instance.new("TextButton", Main)
Fix.Size = UDim2.new(0.8,0,0,40)
Fix.Position = UDim2.new(0.1,0,0.45,0)
Fix.Text = "FIX LAG"
Fix.Font = Enum.Font.GothamBold
Fix.TextScaled = true
Fix.BackgroundColor3 = Color3.fromRGB(50,50,50)
Fix.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", Fix)

local Close = Instance.new("TextButton", Main)
Close.Size = UDim2.new(0,25,0,25)
Close.Position = UDim2.new(1,-30,0,5)
Close.Text = "X"
Close.Font = Enum.Font.GothamBold
Close.TextScaled = true
Close.BackgroundColor3 = Color3.fromRGB(220,60,60)
Close.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", Close)

-- Nút đóng/mở menu
local Toggle = Instance.new("TextButton", ScreenGui)
Toggle.Size = UDim2.new(0,50,0,50)
Toggle.Position = UDim2.new(0.5,-25,0.95,-25)
Toggle.Text = "☰"
Toggle.Font = Enum.Font.GothamBold
Toggle.TextScaled = true
Toggle.BackgroundColor3 = Color3.fromRGB(50,50,50)
Toggle.TextColor3 = Color3.new(1,1,1)
Toggle.ZIndex = 10
Toggle.BorderSizePixel = 0
Toggle.Name = "ToggleButton"
Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0,15)

local isMenuOpen = true

-- Click để mở/đóng menu
local function ToggleMenu()
	isMenuOpen = not isMenuOpen
	Main.Visible = isMenuOpen
end

Toggle.MouseButton1Click:Connect(ToggleMenu)

Close.MouseButton1Click:Connect(function()
    ScreenGui:Destroy()
end)

Fix.MouseButton1Click:Connect(function()
    local Lighting = game:GetService("Lighting")

    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.Brightness = 1
    end)

    for _,v in ipairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter")
        or v:IsA("Trail")
        or v:IsA("Beam")
        or v:IsA("Smoke")
        or v:IsA("Fire")
        or v:IsA("Sparkles") then
            v.Enabled = false
        elseif v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        end
    end

    Fix.Text = "✓ FIXED"
    Fix.BackgroundColor3 = Color3.fromRGB(50,100,50)
end)

spawn(function()
    local offset = 0
    local TweenService = game:GetService("TweenService")
    while ScreenGui.Parent do
        for i, led in ipairs(leds) do
            local idx = ((i + offset - 1) % #colors) + 1
            local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Linear)
            pcall(function()
                TweenService:Create(led, tweenInfo, {BackgroundColor3 = colors[idx]}):Play()
            end)
        end
        offset = offset + 1
        wait(0.25)
    end
end)


local function RemoveAllNPC()
	local function IsNPC(character)
		if not character:FindFirstChild("Humanoid") then return false end
		if character:FindFirstChild("HumanoidRootPart") then
			return true
		end
		return false
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and IsNPC(obj) and obj ~= game.Players.LocalPlayer.Character then
			pcall(function()
				obj:Destroy()
			end)
		end
	end
	
	DeleteNPC.Text = "✓ DELETED"
	DeleteNPC.BackgroundColor3 = Color3.fromRGB(50,100,50)
end

-- Auto Reset logic
local autoResetEnabled = false
local autoResetInterval = 10 -- seconds

local function tryResetPlayer()
    pcall(function()
        local pl = game.Players.LocalPlayer
        if not pl then return end
        -- Only reset if character is nil or dead
        local char = pl.Character
        local humanoid = char and char:FindFirstChild("Humanoid")
        local needReset = false
        if not char then
            needReset = true
        elseif humanoid and humanoid.Health <= 0 then
            needReset = true
        end
        if needReset then
            pl:LoadCharacter()
        end
    end)
end

AutoResetToggle.MouseButton1Click:Connect(function()
    autoResetEnabled = not autoResetEnabled
    if autoResetEnabled then
        AutoResetToggle.Text = "Auto Reset: ON ("..tostring(autoResetInterval).."s)"
        AutoResetToggle.BackgroundColor3 = Color3.fromRGB(50,150,50)
    else
        AutoResetToggle.Text = "Auto Reset: OFF"
        AutoResetToggle.BackgroundColor3 = Color3.fromRGB(80,80,80)
    end
end)

ResetNow.MouseButton1Click:Connect(function()
    tryResetPlayer()
end)

-- Background loop that checks periodically
spawn(function()
    while ScreenGui.Parent do
        if autoResetEnabled then
            wait(autoResetInterval)
            tryResetPlayer()
        else
            wait(0.5)
        end
    end
end)

-- Hàm kiểm tra màu tím
local function IsPurpleColor(color)
	local r, g, b = color.R, color.G, color.B
	-- Kiểm tra nếu màu tím (R cao, B cao, G thấp)
	return r > 0.5 and b > 0.5 and g < 0.5
end

-- Hàm xóa tất cả hiệu ứng màu tím
local function RemoveAllPurpleEffects()
	local removedCount = 0
	
	for _, v in ipairs(game:GetDescendants()) do
		pcall(function()
			if v:IsA("ParticleEmitter") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Trail") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Beam") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
				if v.Color and IsPurpleColor(v.Color) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("BasePart") then
				if v.Color and IsPurpleColor(v.Color) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			end
		end)
	end
	
	DeletePurple.Text = "✓ ĐÃ XÓA"
	DeletePurple.BackgroundColor3 = Color3.fromRGB(50,100,50)
end


-- Fix Lag Function
local function FixLag()
    StatusLabel.Text = "Đang xử lý..."
    local count = 0
    
    pcall(function()
        local Lighting = game:GetService("Lighting")
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.Brightness = 2
    end)
    
    for _, v in ipairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                v:Destroy()
                count = count + 1
            elseif v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                v:Destroy()
                count = count + 1
            end
        end)
    end
    
    FixBtn.Text = "✓ ĐÃ FIX (" .. count .. ")"
    FixBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    StatusLabel.Text = "Xóa " .. count .. " hiệu ứng!"
    
    wait(2)
    FixBtn.Text = "🎨 FIX LAG"
    FixBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 200)
end

-- Remove NPC Function
local function RemoveNPC()
    StatusLabel.Text = "Đang xóa NPC..."
    local count = 0
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= game.Players.LocalPlayer.Character then
                obj:Destroy()
                count = count + 1
            end
        end)
    end
    
    RemoveNPCBtn.Text = "✓ DELETED (" .. count .. ")"
    RemoveNPCBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    StatusLabel.Text = "Xóa " .. count .. " NPC!"
    
    wait(2)
    RemoveNPCBtn.Text = "🗑️ XÓA NPC"
    RemoveNPCBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 100)
end

-- Remove Purple Effects Function
local function RemovePurple()
    StatusLabel.Text = "Đang xóa hiệu ứng tím..."
    local count = 0
    
    for _, v in ipairs(game:GetDescendants()) do
        pcall(function()
            local color = nil
            
            if v:IsA("ParticleEmitter") and v.Color and v.Color.Keypoints and v.Color.Keypoints[1] then
                color = v.Color.Keypoints[1].Value
            elseif v:IsA("Trail") and v.Color and v.Color.Keypoints and v.Color.Keypoints[1] then
                color = v.Color.Keypoints[1].Value
            elseif v:IsA("Beam") and v.Color and v.Color.Keypoints and v.Color.Keypoints[1] then
                color = v.Color.Keypoints[1].Value
            elseif (v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles")) and v.Color then
                color = v.Color
            end
            
            if color then
                local r, g, b = color.R, color.G, color.B
                if r > 0.5 and b > 0.5 and g < 0.5 then
                    v:Destroy()
                    count = count + 1
                end
            end
        end)
    end
    
    RemovePurpleBtn.Text = "✓ REMOVED (" .. count .. ")"
    RemovePurpleBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    StatusLabel.Text = "Xóa " .. count .. " hiệu ứng tím!"
    
    wait(2)
    RemovePurpleBtn.Text = "💜 XÓA HIỆU ỨNG TÍM"
    RemovePurpleBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 150)
end


-- ==================== AUTO FARM CHEST SYSTEM ====================
local FarmEnabled = false
local ChestFolder = Instance.new("Folder", ScreenGui)
ChestFolder.Name = "ChestTracking"

local function FindNearestChest()
	local player = game.Players.LocalPlayer
	if not player or not player.Character then return nil end
	
	local playerPos = player.Character:FindFirstChild("HumanoidRootPart")
	if not playerPos then return nil end
	
	local nearestChest = nil
	local nearestDistance = math.huge
	
	-- Tìm rương trong workspace
	for _, part in ipairs(workspace:FindPartByCFrame(playerPos.CFrame, 500)) do
		if part and part.Name:match("[Cc]hest") then
			local distance = (part.Position - playerPos.Position).Magnitude
			if distance < nearestDistance and distance < 500 then
				nearestChest = part
				nearestDistance = distance
			end
		end
	end
	
	-- Nếu không tìm thấy, tìm trong descendants
	if not nearestChest then
		for _, part in ipairs(workspace:GetDescendants()) do
			if part:IsA("BasePart") and part.Name:match("[Cc]hest") then
				local distance = (part.Position - playerPos.Position).Magnitude
				if distance < nearestDistance and distance < 500 then
					nearestChest = part
					nearestDistance = distance
				end
			end
		end
	end
	
	return nearestChest
end

local function GoToChest()
	local player = game.Players.LocalPlayer
	if not player or not player.Character then return end
	
	local chest = FindNearestChest()
	if chest then
		local hrootpart = player.Character:FindFirstChild("HumanoidRootPart")
		if hrootpart then
			hrootpart.CFrame = chest.CFrame + Vector3.new(0, 5, 0)
			task.wait(0.2)
			hrootpart.CFrame = chest.CFrame
			StatusLabel.Text = "Trạng thái: Đi đến rương"
			StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
		end
	else
		StatusLabel.Text = "Trạng thái: Không tìm thấy rương"
		StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 0)
	end
end


-- Hàm Fix Lag
local function fixLag()
	fixLagBtn.Text = "⏳ Đang tối ưu..."
	fixLagBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 50)
	
	-- Giảm chất lượng đồ họa
	settings().Rendering.QualityLevel = 1
	
	-- Tắt ParticleEmitters
	for _, emitter in pairs(game:GetDescendants()) do
		if emitter:IsA("ParticleEmitter") then
			emitter.Enabled = false
		end
	end
	
	-- Tắt một số effect
	for _, effect in pairs(game:GetDescendants()) do
		if effect:IsA("Beam") or effect:IsA("Trail") then
			effect.Enabled = false
		end
	end
	
	wait(1.5)
	fixLagBtn.Text = "✅ Fix Lag"
	fixLagBtn.BackgroundColor3 = Color3.fromRGB(70, 150, 70)
end

fixLagBtn.MouseButton1Click:Connect(fixLag)

-- ===== Event Listeners =====
toggleBtn.MouseButton1Click:Connect(function()
	menuOpen = not menuOpen
	if menuOpen then
		contentFrame.Visible = true
		toggleBtn.Text = "−"
	else
		contentFrame.Visible = false
		toggleBtn.Text = "+"
	end
end)


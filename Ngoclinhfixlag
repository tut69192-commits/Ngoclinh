local lastTime = tick()
local frameCount = 0
local fps = 0

game:GetService("RunService").RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local currentTime = tick()
    local deltaTime = currentTime - lastTime
    
    if deltaTime >= 1 then
        fps = frameCount
        frameCount = 0
        lastTime = currentTime
    end
    
    FpsLabel.Text = "FPS: " .. fps
end)


-- Fix Lag Function
local function FixLag()
    StatusLabel.Text = "Đang xử lý..."
    local count = 0
    
    pcall(function()
        local Lighting = game:GetService("Lighting")
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 100000
        Lighting.Brightness = 2
    end)
    
    for _, v in ipairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                v:Destroy()
                count = count + 1
            elseif v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                v:Destroy()
                count = count + 1
            end
        end)
    end
    
    FixBtn.Text = "✓ ĐÃ FIX (" .. count .. ")"
    FixBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    StatusLabel.Text = "Xóa " .. count .. " hiệu ứng!"
    
    wait(2)
    FixBtn.Text = "🎨 FIX LAG"
    FixBtn.BackgroundColor3 = Color3.fromRGB(100, 150, 200)
end

-- Remove NPC Function

	screenGui:Destroy()
end)

-- ===== Update Stats =====
RunService.Heartbeat:Connect(function()
	-- Tính FPS
	frameCount = frameCount + 1
	local currentTime = tick()
	if currentTime - lastFpsUpdate >= 1 then
		currentFps = frameCount
		frameCount = 0
		lastFpsUpdate = currentTime
	end
	fpsLabel.Text = "FPS: " .. currentFps
	
	-- Tính thời gian chơi
	local elapsed = tick() - startTime
	local hours = math.floor(elapsed / 3600)
	local minutes = math.floor((elapsed % 3600) / 60)
	local seconds = math.floor(elapsed % 60)
	timeLabel.Text = string.format("Thời gian chơi: %02d:%02d:%02d", hours, minutes, seconds)
end)

-- Cập nhật Ping (nếu có API)
game:GetService("RunService").Heartbeat:Connect(function()
	local ping = math.floor((player:FindFirstChild("Stats") and player.Stats.Network.ServerReplicator.Data.PredictionLatency.Value * 1000) or 0)
	if ping > 0 then
		pingLabel.Text = "Ping: " .. ping .. " ms"
	end
end)


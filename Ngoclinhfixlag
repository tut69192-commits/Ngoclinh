-- Hàm xóa NPC
local function RemoveAllNPC()
	local function IsNPC(character)
		if not character:FindFirstChild("Humanoid") then return false end
		if character:FindFirstChild("HumanoidRootPart") then
			return true
		end
		return false
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and IsNPC(obj) and obj ~= game.Players.LocalPlayer.Character then
			pcall(function()
				obj:Destroy()
			end)
		end
	end
	
	DeleteNPC.Text = "✓ DELETED"
	DeleteNPC.BackgroundColor3 = Color3.fromRGB(50,100,50)
end

-- Hàm kiểm tra màu tím
local function IsPurpleColor(color)
	local r, g, b = color.R, color.G, color.B
	-- Kiểm tra nếu màu tím (R cao, B cao, G thấp)
	return r > 0.5 and b > 0.5 and g < 0.5
end

-- Hàm xóa tất cả hiệu ứng màu tím
local function RemoveAllPurpleEffects()
	local removedCount = 0
	
	for _, v in ipairs(game:GetDescendants()) do
		pcall(function()
			if v:IsA("ParticleEmitter") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Trail") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Beam") then
				if IsPurpleColor(v.Color.Keypoints[1].Value) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
				if v.Color and IsPurpleColor(v.Color) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			elseif v:IsA("BasePart") then
				if v.Color and IsPurpleColor(v.Color) then
					v:Destroy()
					removedCount = removedCount + 1
				end
			end
		end)
	end
	
	DeletePurple.Text = "✓ ĐÃ XÓA"
	DeletePurple.BackgroundColor3 = Color3.fromRGB(50,100,50)
end


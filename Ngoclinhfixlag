-- ==================== ESP SYSTEM ====================
local ESPEnabled = false
local ESPFolder = Instance.new("Folder", ScreenGui)
ESPFolder.Name = "ESPDrawings"

local function CreateESP(player)
	if player == game.Players.LocalPlayer then return end
	
	local espGroup = Instance.new("Folder", ESPFolder)
	espGroup.Name = player.Name
	
	-- Tên người chơi
	local nameLabel = Instance.new("TextLabel", espGroup)
	nameLabel.Name = "NameLabel"
	nameLabel.BackgroundTransparency = 1
	nameLabel.TextScaled = true
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextColor3 = Color3.fromRGB(0, 255, 127)
	nameLabel.ZIndex = 5
	
	-- Khoảng cách
	local distanceLabel = Instance.new("TextLabel", espGroup)
	distanceLabel.Name = "DistanceLabel"
	distanceLabel.BackgroundTransparency = 1
	distanceLabel.TextScaled = true
	distanceLabel.Font = Enum.Font.Gotham
	distanceLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
	distanceLabel.ZIndex = 5
	
	-- Health Bar Background
	local healthBarBg = Instance.new("Frame", espGroup)
	healthBarBg.Name = "HealthBarBg"
	healthBarBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	healthBarBg.BorderSizePixel = 1
	healthBarBg.BorderColor3 = Color3.fromRGB(255, 255, 255)
	healthBarBg.ZIndex = 5
	
	-- Health Bar
	local healthBar = Instance.new("Frame", healthBarBg)
	healthBar.Name = "HealthBar"
	healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
	healthBar.BorderSizePixel = 0
	healthBar.Size = UDim2.new(1, 0, 1, 0)
	healthBar.ZIndex = 6
	
	local humanoid = player.Character:FindFirstChild("Humanoid")
	
	local connection
	connection = game:GetService("RunService").RenderStepped:Connect(function()
		if not ESPEnabled or not player.Character or not humanoid then
			espGroup:Destroy()
			connection:Disconnect()
			return
		end
		
		local character = player.Character
		local hrootpart = character:FindFirstChild("HumanoidRootPart")
		
		if not hrootpart then return end
		
		local camera = workspace.CurrentCamera
		local screenPos, onScreen = camera:WorldToScreenPoint(hrootpart.Position)
		
		if onScreen then
			local distance = (hrootpart.Position - camera.CFrame.Position).Magnitude
			local offset = 30
			
			nameLabel.Text = player.Name
			nameLabel.Size = UDim2.new(0, 100, 0, 20)
			nameLabel.Position = UDim2.new(0, screenPos.X - 50, 0, screenPos.Y - 30)
			
			distanceLabel.Text = math.floor(distance) .. " m"
			distanceLabel.Size = UDim2.new(0, 80, 0, 15)
			distanceLabel.Position = UDim2.new(0, screenPos.X - 40, 0, screenPos.Y - 10)
			
			-- Health Bar
			local healthPercent = humanoid.Health / humanoid.MaxHealth
			healthBarBg.Size = UDim2.new(0, 80, 0, 8)
			healthBarBg.Position = UDim2.new(0, screenPos.X - 40, 0, screenPos.Y + 10)
			
			healthBar.Size = UDim2.new(healthPercent, 0, 1, 0)
			
			if healthPercent > 0.5 then
				healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
			elseif healthPercent > 0.25 then
				healthBar.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
			else
				healthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			end
		else
			nameLabel.Visible = false
			distanceLabel.Visible = false
			healthBarBg.Visible = false
		end
	end)
end

local function UpdateESP()
	if ESPEnabled then
		for _, player in ipairs(game.Players:GetPlayers()) do
			if player ~= game.Players.LocalPlayer and player.Character then
				if not ESPFolder:FindFirstChild(player.Name) then
					CreateESP(player)
				end
			end
		end
	end
end

-- Khi người chơi mới join
game.Players.PlayerAdded:Connect(function(player)
	if ESPEnabled then
		task.wait(0.5)
		if player.Character then
			CreateESP(player)
		end
	end
end)

-- Khi người chơi rời đi
game.Players.PlayerRemoving:Connect(function(player)
	local espGroup = ESPFolder:FindFirstChild(player.Name)
	if espGroup then
		espGroup:Destroy()
	end
end)

-- Toggle ESP
ESPToggle.MouseButton1Click:Connect(function()
